# Copy to .env and fill in your values.
#
# MariaDB 10 on Synology. MariaDB uses the "mysql" connection scheme.
#   mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://USER:PASSWORD@SYNOLOGY_HOST:3307/digital-hygiene"

# --- Auth.js (NextAuth v5) ---
# Generate a secret:  openssl rand -base64 33
AUTH_SECRET="change-me"
# App URL — must match the port you run on and the Google redirect URI below.
NEXTAUTH_URL="http://localhost:3003"

# Google OAuth credentials (Google Cloud Console → APIs & Services → Credentials → OAuth client, "Web application").
# Authorized redirect URI (dev): http://localhost:3003/api/auth/callback/google
GOOGLE_CLIENT_ID="xxxxxxxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxxxxxxx"

# Optional: restrict sign-in to one Google Workspace domain (e.g. thaimooc.ac.th).
# Leave empty / unset to allow any Google account.
# ALLOWED_EMAIL_DOMAIN="thaimooc.ac.th"

# Comma-separated admin emails — only these may open /admin (checked server-side
# against the verified Google session email).
ADMIN_EMAILS="admin1@example.com, admin2@example.com"
