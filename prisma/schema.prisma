// Prisma schema for digital-hygiene
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/lib/generated/prisma"
}

datasource db {
  // MariaDB uses the "mysql" connector.
  provider = "mysql"
}

// ------------------------------------------------------------------
//  Auth.js (NextAuth) models — https://authjs.dev/getting-started/adapters/prisma
// ------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  // Selected once after first Google sign-in (the division gate). Null = not chosen yet.
  division      String?
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ------------------------------------------------------------------
//  Domain
// ------------------------------------------------------------------

// One saved assessment submission. Mirrors the client-side AssessmentRecord shape.
model AssessmentRecord {
  id          String   @id @default(cuid())
  email       String
  division    String
  gaps        Int
  scoreLabel  String
  // task ids the user marked as "not done" — stored as JSON (MySQL/MariaDB has no scalar list)
  selectedIds Json
  createdAt   DateTime @default(now())

  @@index([email])
  @@index([createdAt])
}
