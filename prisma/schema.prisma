// Prisma schema for digital-hygiene
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/lib/generated/prisma"
}

datasource db {
  // MariaDB uses the "mysql" connector.
  provider = "mysql"
}

// ------------------------------------------------------------------
//  Auth.js (NextAuth) models — https://authjs.dev/getting-started/adapters/prisma
// ------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  // Set by the adapter once a Guest (Resend magic-link) sign-in is completed;
  // OAuth providers (Google) don't populate this.
  emailVerified DateTime?
  image         String?
  // Selected once after first sign-in (the division gate). Null = not chosen yet.
  division      String?
  // Set once the user dismisses the one-time 30-day data-retention notice.
  retentionNoticeAcknowledgedAt DateTime?
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ------------------------------------------------------------------
//  Domain
// ------------------------------------------------------------------

// One saved assessment submission. Mirrors the client-side AssessmentRecord shape.
model AssessmentRecord {
  id          String   @id @default(cuid())
  email       String
  division    String
  gaps        Int
  scoreLabel  String
  // task ids the user marked as "not done" — stored as JSON (MySQL/MariaDB has no scalar list)
  selectedIds Json
  createdAt   DateTime @default(now())

  @@index([email])
  @@index([createdAt])
}

// Admin-managed satisfaction survey question. type is "rating" (1-5) or "text" (free text).
model SurveyQuestion {
  id        String   @id @default(cuid())
  order     Int      @default(0)
  text      String
  type      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
}

// One user's set of answers to the satisfaction survey.
model SurveyResponse {
  id        String   @id @default(cuid())
  email     String
  // questionId -> answer (number for "rating", string for "text") — stored as JSON,
  // same reasoning as AssessmentRecord.selectedIds (no scalar map type in MariaDB).
  answers   Json
  createdAt DateTime @default(now())

  @@index([email])
  @@index([createdAt])
}

// Admin-managed checklist item shown on the main assessment page, grouped by
// one of the 4 fixed ACTIVITY_GROUPS (@/models/activity-group) via groupId.
model ChecklistItem {
  id        String   @id @default(cuid())
  order     Int      @default(0)
  groupId   String
  category  String
  title     String
  severity  String
  impact    String   @db.Text
  action    String   @db.Text
  // Admin-authored step-by-step instructions shown via "เปิดคู่มือ" — plain text,
  // optional (empty until an admin fills it in).
  guide     String   @default("") @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
  @@index([groupId])
}
